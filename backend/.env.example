# Generic backend configuration
FRONTEND_ORIGIN=http://localhost:3000
SIMULATION_ONLY=true

# AI provider settings
# AI_PROVIDER=auto will treat anthropic.com or /messages URLs as Anthropic.
# Everything else is treated as OpenAI-compatible.
AI_PROVIDER=auto
AI_API_BASE_URL=http://localhost:8000/v1
AI_API_KEY=EMPTY

# Model choices
# Use a vision-capable model for AI_ANALYSIS_MODEL.
# Qwen/Qwen2.5-Omni-7B and Qwen/Qwen2.5-VL-3B-Instruct are good OpenAI-compatible examples.
AI_ANALYSIS_MODEL=Qwen/Qwen2.5-Omni-7B
AI_DEBRIEF_MODEL=Qwen/Qwen2.5-Omni-7B

# Request tuning
AI_TIMEOUT_SECONDS=60
AI_ANALYSIS_MAX_TOKENS=1400
AI_DEBRIEF_MAX_TOKENS=1200
AI_SAFETY_MAX_TOKENS=600
HUMAN_REVIEW_CONFIDENCE_THRESHOLD=0.78

# Anthropic-only request header version
ANTHROPIC_VERSION=2023-06-01
